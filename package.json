{
  "packageManager": "yarn@4.17.1",
  "name": "svgo.dev",
  "version": "0.0.0",
  "description": "Landing page and documentation for SVGO.",
  "license": "MIT",
  "homepage": "https://svgo.dev",
  "private": true,
  "author": {
    "name": "Seth Falco",
    "email": "seth@falco.fun",
    "url": "https://falco.fun"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/svgo"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/svg/svgo.dev.git"
  },
  "bugs": {
    "url": "https://github.com/svg/svgo.dev/issues"
  },
  "keywords": [
    "svgo",
    "docusaurus"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "svgo:clone": "rimraf .svgo && git clone https://github.com/svg/svgo.git .svgo --depth 1",
    "svgo:copy": "rimraf .svgo && cp -r ../svgo .svgo",
    "optimize-svgs": "npx svgo --pretty --indent 2 ./src/vectors/*",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "typecheck": "tsc",
    "a11y": "node ./pa11y.mjs",
    "a11y:ci": "start-server-and-test 'yarn run serve --no-open' 'http://localhost:3000' 'yarn run a11y'",
    "qa": "yarn run lint && yarn run typecheck && yarn run a11y:ci",
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "catalog:docusaurus",
    "@docusaurus/plugin-client-redirects": "catalog:docusaurus",
    "@docusaurus/plugin-content-docs": "catalog:docusaurus",
    "@docusaurus/plugin-content-pages": "catalog:docusaurus",
    "@docusaurus/plugin-sitemap": "catalog:docusaurus",
    "@docusaurus/plugin-svgr": "catalog:docusaurus",
    "@docusaurus/theme-classic": "catalog:docusaurus",
    "@docusaurus/theme-common": "catalog:docusaurus",
    "@docusaurus/theme-live-codeblock": "catalog:docusaurus",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "rehype-stringify": "^10.0.1",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "catalog:docusaurus",
    "@docusaurus/types": "catalog:docusaurus",
    "@sethfalco/eslint-config": "^1.2.1",
    "@types/node": "^26.1.0",
    "@types/pa11y": "^5.3.7",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "pa11y": "^9.1.1",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3"
  }
}
